{
  "name": "badminton-e2e-tests",
  "version": "1.0.0",
  "description": "E2E tests for Badminton Training System",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed --project=chromium",
    "test:headed-slow": "playwright test training-session --headed --project=chromium --slow-mo=500",
    "test:debug": "PWDEBUG=1 playwright test --project=chromium",
    "report": "playwright show-report playwright-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/node": "^20.10.0",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "socket.io-client": "^4.5.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
